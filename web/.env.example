# Copy to .env.local and fill in for a REAL Firebase project (cloud deploy).
# For local development against the emulators you can leave these unset - the app
# falls back to the "demo-mzansimoney" demo project and connects to the emulators.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Cloud Functions region. Must match FUNCTIONS_REGION in functions/.env and the
# region you chose for Firestore. Defaults to africa-south1 if unset.
# VITE_FUNCTIONS_REGION=africa-south1

# Force emulator mode on/off explicitly. Defaults to true in `vite dev`.
# VITE_USE_EMULATORS=true
