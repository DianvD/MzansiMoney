# Copy to functions/.env for a real cloud deploy. The Firebase CLI loads this file
# at deploy time. functions/.env is gitignored (it may hold secrets) - never commit it.

# Cloud Functions region - the ONE place to set the backend region. Must match the
# region you chose for Firestore/Storage and the web client's VITE_FUNCTIONS_REGION.
# Defaults to africa-south1 if unset.
FUNCTIONS_REGION=africa-south1

# Gmail auto-import (optional) - only needed if you wire up the Apps Script intake.
# GMAIL_INTAKE_SECRET=
# GMAIL_OWNER_UID=
